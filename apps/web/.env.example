# diBoaS Web App Environment Variables
# Copy this file to .env.local and fill in your values
#
# ──────────────────────────────────────────────────────────────────────────────
# SECRET ROTATION POLICY (90-day cycle)
# ──────────────────────────────────────────────────────────────────────────────
# The following secrets MUST be rotated every 90 days in production:
#   - ENCRYPTION_KEY        (AES-256-GCM — re-encrypt stored PII after rotation)
#   - HMAC_KEY              (HMAC-SHA256 — re-hash all email_hash columns after rotation)
#   - RESEND_API_KEY        (regenerate in Resend dashboard)
#   - INTERNAL_API_KEY      (coordinate with all internal consumers)
#   - UPSTASH_REDIS_REST_TOKEN  (regenerate in Upstash console)
#
# Rotation process:
#   1. Generate new secret value
#   2. Deploy new value alongside old (dual-read period if applicable)
#   3. Verify all services accept the new secret
#   4. Remove old secret
#   5. Record rotation date in team password manager
# ──────────────────────────────────────────────────────────────────────────────

# =============================================================================
# APPLICATION
# =============================================================================

# Base URL for the application (used for referral links, OG images, etc.)
NEXT_PUBLIC_APP_URL=https://diboas.com

# Base domain (without protocol)
NEXT_PUBLIC_APP_DOMAIN=diboas.com

# Node environment (development, production, test)
NODE_ENV=development

# =============================================================================
# DATABASE (Neon PostgreSQL)
# =============================================================================

# Neon PostgreSQL connection string
# Get from https://console.neon.tech — use the "Connection string" with pooler
DATABASE_URL=

# =============================================================================
# EMAIL (Resend)
# =============================================================================

# Resend API key (from https://resend.com/api-keys)
RESEND_API_KEY=

# Verified sender email address
EMAIL_FROM_ADDRESS=diBoaS <noreply@diboas.com>

# Reply-to email address
EMAIL_REPLY_TO=support@diboas.com

# =============================================================================
# CAL.COM INTEGRATION
# =============================================================================

# Cal.com calendar link for booking calls (e.g., "diboas/sales-call")
NEXT_PUBLIC_CAL_LINK=

# Cal.com embed script URL
NEXT_PUBLIC_CAL_EMBED_SCRIPT=https://app.cal.com/embed/embed.js

# Cal.com origin for initialization
NEXT_PUBLIC_CAL_ORIGIN=https://app.cal.com

# Cal.com B2B treasury conversation link
NEXT_PUBLIC_CAL_TREASURY_LINK=diboas/treasury-conversation

# =============================================================================
# WAITLIST STORAGE
# =============================================================================

# Waitlist stats override (optional - for manual control of social proof display)
# Set these to override live store data with fixed values
NEXT_PUBLIC_WAITLIST_COUNT=0
NEXT_PUBLIC_WAITLIST_COUNTRIES=0

# Founding member cap — B2C (default: 1200, overridable at runtime)
FOUNDING_MEMBER_CAP=1200
# Founding member cap — B2B (default: 24)
FOUNDING_MEMBER_CAP_B2B=24
# Client-side founding member cap (mirrors server-side FOUNDING_MEMBER_CAP for UI display)
NEXT_PUBLIC_FOUNDING_MEMBER_CAP=1200
# Client-side B2B founding member cap (mirrors FOUNDING_MEMBER_CAP_B2B for UI display)
NEXT_PUBLIC_FOUNDING_MEMBER_CAP_B2B=24

# Adelaide Daily / /market route indexability gate
# - false (iterations 1-3): page rendered with noindex/nofollow meta;
#   not added to sitemap; placeholder + curated-manual content phase.
# - true (iteration 4 launch, flipped 2026-05-20): real content live,
#   calm-audit signed off (§3.3), Lighthouse remediation closed (§3.2 at perf 84
#   post-lazy-load + preconnect quick wins), route is search-indexable.
#   Production Vercel env var must also be flipped to 'true' separately.
# Consumed by apps/web/src/app/[locale]/(landing)/market/page.tsx generateMetadata.
NEXT_PUBLIC_MARKET_INDEXABLE=true

# Adelaide Daily / analytics-product API base URL (2026-05-14, iteration 2)
# - `/_mock` (default, iterations 2-4): mock SDK reads from local fixtures in
#   apps/web/src/lib/analytics-sdk/fixtures/; no network calls made.
# - https://api.diboas-analytics.com (iteration 5): real `@analytics-platform/client`
#   SDK swap; CSP `connect-src` already allows this host (see middleware.ts).
# - https://staging.api.diboas-analytics.com (dev): staging API.
NEXT_PUBLIC_ANALYTICS_API_URL=/_mock

# Internal API key for position updates (used by webhooks)
# Generate a random string for production
INTERNAL_API_KEY=

# =============================================================================
# ANALYTICS & MONITORING
# =============================================================================
# Operational reference: docs/tech/MONITORING_OPS.md (committed playbook)
# Org-specific values (current DSN, project IDs, dashboard links):
#   docs/monitoring/INFRASTRUCTURE_GUIDE.md (local-only)
#
# Verification procedures after rotating any of these — see MONITORING_OPS.md § F.

# Google Analytics 4 Measurement ID (e.g., G-XXXXXXXXXX)
# Loading: next/script with strategy="afterInteractive" + Consent Mode v2.
# Pre-consent: GA4 loads in "consent-denied" mode (no cookies, anonymised pings).
NEXT_PUBLIC_GA_ID=

# Sentry DSN for error tracking + session replay (browser-side runtime var).
#
# CRITICAL — verify the DSN's project key is ACTIVE before deploying.
# Sentry → Settings → Projects → <project> → Client Keys (DSN). Each project can
# have multiple keys, any of which can be silently disabled. A disabled key:
#   - Accepts incoming envelope POSTs
#   - Returns HTTP 403 with `with_reason: ProjectId`
#   - Drops 100% of events
#   - Does NOT surface anywhere in the Sentry UI as "you have a disabled key in use"
# We had 3 months of silent dropout in early 2026 because the Default key was
# disabled when a new key was provisioned but the env var still pointed at the
# old (disabled) DSN. See docs/audit/SECURITY_FINDINGS_2026-05.md § F16.
#
# After rotation: trigger a test event per MONITORING_OPS.md § F.1 and confirm
# the event appears in the Sentry dashboard within 30 seconds.
NEXT_PUBLIC_SENTRY_DSN=

# Sentry build-time secrets — used by the @sentry/nextjs Webpack plugin to
# upload source maps and tag releases during `next build`.
#
# CRITICAL — all three must be listed in turbo.json#tasks.build.env (and .dev.env
# if you need them in dev), otherwise Turborepo silently scrubs them and the
# Sentry plugin skips source map upload without failing the build. The only
# symptom is minified stack traces in production Sentry issues. See
# MONITORING_OPS.md § E.1 (Turborepo env passthrough).
#
# These are server-side build secrets, NOT NEXT_PUBLIC_*. Do not expose to the
# browser bundle. Mark them as "Sensitive" in Vercel (writable-once; rotate by
# delete+recreate). See MONITORING_OPS.md § E.4 (Vercel "Sensitive" flag).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# PostHog API key for analytics (the "project token" — write-only key, safe to be public)
NEXT_PUBLIC_POSTHOG_KEY=

# PostHog ingest host. MUST contain `.i.posthog.com` (the SDK derives the
# static-asset host by string-replacing `.i.` → `-assets.i.` on this value).
# Use the matching INGEST endpoint for your PostHog account region:
#   US Cloud:    https://us.i.posthog.com
#   EU Cloud:    https://eu.i.posthog.com
# Do NOT use console URLs (us.posthog.com / app.posthog.com / eu.posthog.com) —
# these break the asset-host derivation and cause `/array/<key>/config.js` to
# 404 against your own domain. The SDK silently degrades (no feature flags, no
# surveys, no session replay) without throwing or logging an error.
# See MONITORING_OPS.md § C and § E.6.
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# =============================================================================
# SECURITY
# =============================================================================

# AES-256-GCM encryption key for PII (email, name)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# HMAC-SHA256 key for blind index lookups (email_hash column)
# MUST be different from ENCRYPTION_KEY for cryptographic separation.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Falls back to ENCRYPTION_KEY in dev if not set.
# WARNING: Rotating this key breaks ALL email_hash lookups — must re-hash all rows.
HMAC_KEY=

# =============================================================================
# CSRF PROTECTION
# =============================================================================

# Additional allowed origins for CSRF validation (comma-separated)
# Example: "https://staging.diboas.com,https://preview.diboas.com"
CSRF_ADDITIONAL_ORIGINS=

# =============================================================================
# RATE LIMITING
# =============================================================================

# Upstash Redis for distributed rate limiting (optional, falls back to in-memory)
# Get credentials from https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Rate limit prefix for Redis keys
RATE_LIMIT_PREFIX=diboas-ratelimit

# Strict rate limit (for sensitive endpoints like signup)
RATE_LIMIT_STRICT_LIMIT=5
RATE_LIMIT_STRICT_WINDOW_MS=60000

# Standard rate limit (for general API endpoints)
RATE_LIMIT_STANDARD_LIMIT=30
RATE_LIMIT_STANDARD_WINDOW_MS=60000

# Lenient rate limit (for read-only endpoints)
RATE_LIMIT_LENIENT_LIMIT=100
RATE_LIMIT_LENIENT_WINDOW_MS=60000

# =============================================================================
# COOKIE & STORAGE CONFIGURATION
# =============================================================================

# Storage key prefix (used for localStorage, cookies, etc.)
NEXT_PUBLIC_STORAGE_PREFIX=diboas

# Cookie consent settings
COOKIE_CONSENT_NAME=diboas-consent
COOKIE_CONSENT_VERSION=1.0
COOKIE_CONSENT_LS_KEY=diboas-cookie-consent
COOKIE_MAX_AGE=31536000

# Waitlist storage key
WAITLIST_STORAGE_KEY=diboas_waiting_list

# Referral cookie settings
REFERRAL_COOKIE_NAME=diboas_ref
REFERRAL_COOKIE_EXPIRY_DAYS=30
REFERRAL_CODE_PREFIX=REF

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable Cal.com booking (set to "true" when configured)
NEXT_PUBLIC_ENABLE_BOOKING=false

# Enable waitlist referral mechanics
NEXT_PUBLIC_ENABLE_REFERRALS=true

# Wallet architecture for FAQ "Is my money safe?" answer selection
# Valid values: 'non-custodial' (Version A) | 'mpc' (Version B)
# Default: non-custodial. Requires rebuild to take effect.
NEXT_PUBLIC_WALLET_ARCHITECTURE=non-custodial

# =============================================================================
# BRAND & COMPANY INFORMATION
# =============================================================================

# Brand identity
NEXT_PUBLIC_BRAND_NAME=diBoaS
NEXT_PUBLIC_BRAND_FULL_NAME=diBoaS
NEXT_PUBLIC_BRAND_TAGLINE=Building Your Financial Future
NEXT_PUBLIC_BRAND_DESCRIPTION=Democratizing finance through technology

# Company details
NEXT_PUBLIC_COMPANY_NAME=diBoaS
NEXT_PUBLIC_COMPANY_LEGAL_NAME=diBoaS Inc.
NEXT_PUBLIC_FOUNDING_DATE=2024

# Company address (for legal pages)
NEXT_PUBLIC_COMPANY_STREET=
NEXT_PUBLIC_COMPANY_CITY=
NEXT_PUBLIC_COMPANY_STATE=
NEXT_PUBLIC_COMPANY_ZIP=
NEXT_PUBLIC_COMPANY_COUNTRY=

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# App version (displayed in health checks)
NEXT_PUBLIC_APP_VERSION=1.0.0

# Default locale and currency
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_DEFAULT_CURRENCY=USD

# Site domain (used for SEO and OG images)
NEXT_PUBLIC_BASE_URL=https://diboas.com
NEXT_PUBLIC_SITE_DOMAIN=diboas.com

# =============================================================================
# SOCIAL MEDIA LINKS
# =============================================================================

# Social media URLs (leave empty to hide)
NEXT_PUBLIC_TWITTER_URL=
NEXT_PUBLIC_TWITTER_HANDLE=@diboas
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_YOUTUBE_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_GITHUB_URL=

# =============================================================================
# SEO & VERIFICATION
# =============================================================================

# Google Search Console verification
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools verification
NEXT_PUBLIC_BING_VERIFICATION=

# =============================================================================
# LOGGING & ERROR REPORTING
# =============================================================================

# Remote logging endpoint (optional)
NEXT_PUBLIC_LOGGING_ENDPOINT=

# Enable detailed logging in production
NEXT_PUBLIC_ENABLE_DETAILED_LOGGING=false

# Enable error reporting
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=true

# =============================================================================
# MONITORING SERVICES (Optional)
# =============================================================================

# Sentry org/project — referenced by apps/web/src/config/monitoring.ts SENTRY_CONFIG
# for client-side telemetry tagging. NOT the same as the SENTRY_ORG / SENTRY_PROJECT
# (without NEXT_PUBLIC_) used by the @sentry/nextjs build plugin to upload source
# maps — those live in the ANALYTICS & MONITORING block above and must be passed
# through turbo.json#env. See MONITORING_OPS.md § B for the full breakdown.
NEXT_PUBLIC_SENTRY_ORG=
NEXT_PUBLIC_SENTRY_PROJECT=

# Performance monitoring
NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING=true

# =============================================================================
# ALERTING & NOTIFICATIONS (Optional)
# =============================================================================

# Slack webhook for alerts
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#alerts

# Email alerts
ALERT_EMAIL_ENDPOINT=
ALERT_EMAIL_RECIPIENTS=

# =============================================================================
# ADVANCED MONITORING SERVICES (Optional)
# =============================================================================

# DataDog APM
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com

# Grafana Cloud
GRAFANA_API_KEY=
GRAFANA_ORG=
NEXT_PUBLIC_GRAFANA_URL=

# New Relic
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_API_KEY=
NEW_RELIC_APP_ID=
NEW_RELIC_ACCOUNT_ID=

# LogRocket Session Replay
NEXT_PUBLIC_LOGROCKET_APP_ID=

# Generic monitoring endpoints
MONITORING_API_KEY=
NEXT_PUBLIC_MONITORING_ENDPOINT=
ERROR_REPORTING_API_KEY=
ERROR_REPORTING_ENDPOINT=
NEXT_PUBLIC_ERROR_REPORTING_ENDPOINT=

# Analytics endpoint (for custom analytics)
NEXT_PUBLIC_ANALYTICS_ENDPOINT=
PERFORMANCE_MONITORING_API_KEY=
PERFORMANCE_MONITORING_ENDPOINT=
PERFORMANCE_BUDGET_ALERTS=false

# =============================================================================
# BUSINESS METRICS (For Landing Pages)
# =============================================================================

# Statistics displayed on landing pages
NEXT_PUBLIC_USER_COUNT=10000
NEXT_PUBLIC_COUNTRIES_SERVED=50
NEXT_PUBLIC_VOLUME_PROCESSED=$1B+
NEXT_PUBLIC_TPS=1000
NEXT_PUBLIC_UPTIME_GUARANTEE=99.99%
NEXT_PUBLIC_API_RESPONSE_TIME=<100ms
NEXT_PUBLIC_CUSTOMER_SAT=4.8/5
NEXT_PUBLIC_GROWTH_RATE=150%

# =============================================================================
# COMPLIANCE & SECURITY BADGES
# =============================================================================

NEXT_PUBLIC_SECURITY_CERTS=SOC2,ISO27001
NEXT_PUBLIC_DATA_PROTECTION=GDPR,CCPA
NEXT_PUBLIC_REGULATORY_COMPLIANCE=PCI-DSS
NEXT_PUBLIC_SECURITY_UPDATES=Daily
NEXT_PUBLIC_AUDIT_FREQUENCY=Quarterly

# =============================================================================
# SUPPORT INFORMATION
# =============================================================================

NEXT_PUBLIC_SUPPORT_EMAIL=support@diboas.com
NEXT_PUBLIC_SUPPORT_PHONE=
NEXT_PUBLIC_RESOLUTION_TIME=<24h

# =============================================================================
# UI CONFIGURATION
# =============================================================================

# Page title template
NEXT_PUBLIC_TITLE_TEMPLATE=%s

# Base body class
NEXT_PUBLIC_BODY_BASE_CLASS=antialiased

# CDN URL for assets (if using external CDN)
NEXT_PUBLIC_CDN_URL=

# Business landing page URL
NEXT_PUBLIC_BUSINESS_URL=/business

# Learn section URL
NEXT_PUBLIC_LEARN_URL=/learn

# Base URL (alternative to APP_URL)
NEXT_PUBLIC_BASE_URL=https://diboas.com

# =============================================================================
# ADDITIONAL SEO VERIFICATION
# =============================================================================

# Yandex Webmaster verification
NEXT_PUBLIC_YANDEX_VERIFICATION=

# =============================================================================
# RUNTIME CONFIGURATION
# =============================================================================

# Next.js runtime (nodejs or edge)
NEXT_RUNTIME=nodejs

# App environment (development, staging, production)
APP_ENV=development

# Next.js build phase detection (auto-set by Next.js — do not set manually)
# NEXT_PHASE=

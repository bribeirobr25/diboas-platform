{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "apps/web": {
      "eslint": false,
      "entry": [
        "src/app/**/page.tsx",
        "src/app/**/layout.tsx",
        "src/app/**/route.ts",
        "src/app/**/loading.tsx",
        "src/app/**/error.tsx",
        "src/app/**/not-found.tsx",
        "src/app/**/global-error.tsx",
        "src/app/**/opengraph-image.{ts,tsx}",
        "src/app/**/twitter-image.{ts,tsx}",
        "src/app/**/icon.{ts,tsx}",
        "src/app/**/manifest.{ts,json}",
        "src/app/sitemap.ts",
        "src/app/globals.css",
        "middleware.ts",
        "src/instrumentation.ts",
        "src/instrumentation-client.ts",
        "src/test/**",
        "src/types/**",
        "src/styles/**",
        "src/config/**",
        "src/components/**/*.stories.tsx",
        "next.config.*",
        "postcss.config.*",
        "tailwind.config.*",
        "sentry.*.config.*",
        "vitest.config.ts",
        "eslint.config.mjs"
      ],
      "project": ["src/**/*.{ts,tsx,js,jsx}", "middleware.ts", "next.config.*", "postcss.config.*", "tailwind.config.*", "sentry.*.config.*", "vitest.config.ts", "eslint.config.mjs"],
      "ignore": [
        "src/**/*.test.{ts,tsx}"
      ],
      "ignoreDependencies": [
        "autoprefixer",
        "@next/bundle-analyzer",
        "eslint-config-next",
        "storybook",
        "@storybook/*",
        "eslint-plugin-storybook",
        "@lhci/cli",
        "pa11y"
      ]
    },
    "packages/i18n": {
      "entry": ["src/index.ts", "src/server.ts", "src/client.ts", "src/config.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/ui": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/email": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    }
  }
}
